{
  "experiment": {
    "name": "vectordb_phase2_suite",
    "seed": 42,
    "repeats": 1,
    "output_dir": "results",
    "notes": "Config-driven benchmark suite for ANN, concurrency, and filtering"
  },
  "dataset": {
    "name": "open-vdb/sift-128-euclidean",
    "sizes": [100000],
    "query_count": 200,
    "top_k": 10
  },
  "backends": [
    "milvus",
    "qdrant"
  ],
  "ann": {
    "enabled": true,
    "hnsw_ef_values": [64, 128, 256]
  },
  "concurrency": {
    "enabled": true,
    "concurrency_levels": [1, 2, 4, 8, 16]
  },
  "filtering": {
    "enabled": true,
    "selectivities": [0.5, 0.1, 0.01]
  },
  "hybrid": {
    "enabled": false,
    "mode": "metadata_rerank_placeholder"
  }
}
